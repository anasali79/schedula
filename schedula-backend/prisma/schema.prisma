generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Appointment {
  id              String            @id @default(uuid())
  patientId       String
  doctorId        String
  slotId          String
  appointmentDate DateTime
  status          AppointmentStatus @default(CONFIRMED)
  notes           String?
  isRescheduled   Boolean           @default(false)
  elasticSlotId   String?
  originalSlotId  String?
  checkedInAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  doctor          Doctor            @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  slot            AvailabilitySlot  @relation(fields: [slotId], references: [id], onDelete: Cascade)
  rescheduleQueue RescheduleQueue?
  slotAllocation  SlotAllocation?

  @@unique([patientId, appointmentDate, slotId], name: "patient_appointment_unique")
}

model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  createdAt          DateTime            @default(now())
  googleId           String?             @unique
  isVerified         Boolean             @default(false)
  passwordHash       String?
  provider           AuthProvider        @default(LOCAL)
  refreshTokenHash   String?
  role               Role?
  updatedAt          DateTime            @updatedAt
  doctor             Doctor?
  patient            Patient?
  verificationTokens VerificationToken[]
}

model Doctor {
  id              String           @id @default(uuid())
  userId          String           @unique
  firstName       String
  lastName        String?
  licenseNumber   String?
  approvalStatus  ApprovalStatus   @default(PENDING)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  appointments    Appointment[]
  availabilities  Availability[]
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  elasticSlots    ElasticSlot[]
  profile         Profile?
  specializations Specialization[]
}

model Patient {
  id           String        @id @default(uuid())
  userId       String        @unique
  firstName    String
  lastName     String?
  phone        String?
  dob          DateTime?
  gender       String?
  bloodGroup   String?
  address      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Profile {
  id              String   @id @default(uuid())
  doctorId        String   @unique
  bio             String?
  experienceYears Int?
  consultationFee Decimal? @db.Decimal(10, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  doctor          Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model Specialization {
  id        String   @id @default(uuid())
  doctorId  String
  name      String
  createdAt DateTime @default(now())
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model Availability {
  id                  String             @id @default(uuid())
  doctorId            String
  dayOfWeek           Int?
  scheduleType        ScheduleType       @default(STREAM)
  consultingStartTime String
  consultingEndTime   String
  maxAppt             Int                @default(0)
  session             String?
  slotDuration        Int?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  date                DateTime?
  doctor              Doctor             @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  slots               AvailabilitySlot[]
  elasticSlots        ElasticSlot[]
}

model AvailabilitySlot {
  id             String        @id @default(uuid())
  availabilityId String
  startTime      String
  endTime        String
  maxAppt        Int
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  appointments   Appointment[]
  availability   Availability  @relation(fields: [availabilityId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ElasticSlot {
  id             String           @id @default(uuid())
  doctorId       String
  availabilityId String?
  sessionDate    DateTime
  startTime      String
  endTime        String
  slotDuration   Int
  maxPerSlot     Int
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  availability   Availability?    @relation(fields: [availabilityId], references: [id], onDelete: Cascade)
  doctor         Doctor           @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  allocations    SlotAllocation[]

  @@index([doctorId, sessionDate])
}

model SlotAllocation {
  id            String      @id @default(uuid())
  elasticSlotId String
  appointmentId String      @unique
  status        String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  elasticSlot   ElasticSlot @relation(fields: [elasticSlotId], references: [id], onDelete: Cascade)
}

model RescheduleQueue {
  id            String      @id @default(uuid())
  appointmentId String      @unique
  reason        String
  priority      Int         @default(0)
  notifiedAt    DateTime?
  resolvedAt    DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

enum Role {
  PATIENT
  DOCTOR
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AppointmentStatus {
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum ScheduleType {
  STREAM
  WAVE
}
