datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  PATIENT
  DOCTOR
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AppointmentStatus {
  CONFIRMED
  CANCELLED
  COMPLETED
}

model Appointment {
  id              String            @id @default(uuid())
  patientId       String
  patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId        String
  doctor          Doctor            @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  slotId          String
  slot            AvailabilitySlot  @relation(fields: [slotId], references: [id], onDelete: Cascade)
  
  appointmentDate DateTime          // The actual date of the appointment
  status          AppointmentStatus @default(CONFIRMED)
  notes           String?
  isRescheduled   Boolean           @default(false)
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([patientId, appointmentDate, slotId], name: "patient_appointment_unique")
}

model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  passwordHash       String? // null for Google users
  role               Role?
  provider           AuthProvider        @default(LOCAL)
  isVerified         Boolean             @default(false)
  googleId           String?             @unique
  refreshTokenHash   String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  verificationTokens VerificationToken[]
  doctor             Doctor?
  patient            Patient?
}

model Doctor {
  id              String           @id @default(uuid())
  userId          String           @unique
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName       String
  lastName        String?
  licenseNumber   String?
  approvalStatus  ApprovalStatus   @default(PENDING)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  profile         Profile?
  specializations Specialization[]
  availabilities  Availability[]
  appointments    Appointment[]
}

model Patient {
  id           String        @id @default(uuid())
  userId       String        @unique
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName    String
  lastName     String?
  phone        String?
  dob          DateTime?
  gender       String?
  bloodGroup   String?
  address      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
}

model Profile {
  id                String   @id @default(uuid())
  doctorId          String   @unique
  doctor            Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  bio               String?
  experienceYears   Int?
  consultationFee   Decimal? @db.Decimal(10, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Specialization {
  id        String   @id @default(uuid())
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())
}

enum ScheduleType {
  STREAM
  WAVE
}

model Availability {
  id       String @id @default(uuid())
  doctorId String
  doctor   Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  // Day of week (0=Sunday, 1=Monday, ... 6=Saturday) - for Recurring
  dayOfWeek Int?

  // Specific date - for Custom availability
  date      DateTime?

  scheduleType ScheduleType @default(STREAM)

  consultingStartTime String
  consultingEndTime   String
  maxAppt             Int     @default(0)
  session             String? // e.g. "Morning", "Evening"

  // WAVE mode fields
  slotDuration Int? // In minutes

  // STREAM mode fields
  streamInterval  Int? // In minutes
  streamBatchSize Int? // Patients per batch/stream

  slots AvailabilitySlot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AvailabilitySlot {
  id             String       @id @default(uuid())
  availabilityId String
  availability   Availability @relation(fields: [availabilityId], references: [id], onDelete: Cascade)

  startTime String
  endTime   String
  maxAppt   Int // Appointments allowed for this specific slot

  appointments Appointment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

